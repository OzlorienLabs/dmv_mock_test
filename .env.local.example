# Firebase web config. Copy this file to `.env.local` and fill in the values
# from your Firebase project (Project settings → Your apps → SDK setup).
# Leaving these blank keeps the app in guest / on-device-only mode.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# For local development against the Firebase Local Emulator Suite, set this to
# "true" (auth + Firestore will connect to 127.0.0.1:9099 / :8080):
# NEXT_PUBLIC_FIREBASE_EMULATOR=true

# ---------------------------------------------------------------------------
# SEO / discoverability.
# ---------------------------------------------------------------------------
# Your production origin (no trailing slash). Drives canonical URLs, Open Graph
# tags, the sitemap (/sitemap.xml) and JSON-LD. IMPORTANT: set this to your real
# domain before launch — otherwise those URLs use a placeholder.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional Google Analytics 4. When a measurement id is set the GA gtag.js
# snippet loads on every page; leave it unset to ship with zero tracking. Either
# var works — NEXT_PUBLIC_GA_ID (client-safe) takes precedence over the
# server-only GOOGLE_ANALYTICS_ID below (which is read server-side in the layout).
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# Android app (Trusted Web Activity). Serves /.well-known/assetlinks.json so the
# published app verifies against this domain and drops the browser URL bar.
# See android/README.md. Server-side (read at request time).
# ---------------------------------------------------------------------------
# ANDROID_PACKAGE_NAME=com.ozlorienlabs.dmvpractice
# Comma-separated SHA-256 signing fingerprints — include BOTH your upload key
# AND Google's Play app-signing key (Play Console → App integrity):
# ANDROID_CERT_FINGERPRINTS=AA:BB:CC:...,11:22:33:...

# ---------------------------------------------------------------------------
# Server-only (NOT exposed to the browser) — needed for AI "Explain in Audio"
# in custom languages (bring-your-own-key). See AUDIO_SETUP.md.
# ---------------------------------------------------------------------------

# Firebase Admin credentials (one of these). Used to verify ID tokens and to
# read/write user data server-side.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}   # full JSON, one line
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# FIREBASE_ADMIN_ENABLED=true   # when running on GCP with Application Default Credentials

# 32-byte hex key used to encrypt each user's Gemini key at rest.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# GEMINI_KEY_ENCRYPTION_KEY=

# Optional: override the Gemini text model id.
# GEMINI_TEXT_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Feedback modal ("Built with curiosity and care — by Ozlorien Labs").
# The /api/feedback route emails submissions via Resend and (if Firebase Admin
# is configured) also saves them to a 'feedback' Firestore collection. With
# none of this set, the modal falls back to a mailto: link.
# ---------------------------------------------------------------------------
# Resend API key (https://resend.com → API Keys). Server-only.
# RESEND_API_KEY=re_xxxxxxxx
# Where feedback is sent (defaults to ozlorienlabs@gmail.com):
# FEEDBACK_TO=ozlorienlabs@gmail.com
# Verified sender (use a domain you've verified in Resend; onboarding@resend.dev
# works only for sending to your own Resend account email during testing):
# FEEDBACK_FROM=Ozlorien Labs <feedback@yourdomain.com>
