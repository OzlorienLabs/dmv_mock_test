{
  "name": "dmv_mock_test",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "emulators": "firebase emulators:start --only auth,firestore",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "icons": "node scripts/generate-icons.mjs",
    "android:doctor": "npx --yes @bubblewrap/cli doctor",
    "android:update": "cd android && npx --yes @bubblewrap/cli update",
    "android:build": "cd android && npx --yes @bubblewrap/cli update && npx --yes @bubblewrap/cli build",
    "android:install": "cd android && npx --yes @bubblewrap/cli install"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.10.0",
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "firebase-tools": "^15.22.4",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.9"
  }
}
