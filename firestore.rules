rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public, read-only content. (The question bank currently ships in-app; these
    // rules are ready for when content is also served from Firestore.)
    match /questions/{id}    { allow read: if true; allow write: if false; }
    match /diagrams/{id}     { allow read: if true; allow write: if false; }
    match /mockTests/{id}    { allow read: if true; allow write: if false; }
    match /roadTestGuide/{id} { allow read: if true; allow write: if false; }

    // Pre-generated explanation text/audio (public read; written by the
    // owner-run generation script via the Admin SDK).
    match /audio/{id} { allow read: if true; allow write: if false; }

    // Per-user data: only the authenticated owner may read or write.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /attempts/{attemptId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /progress/{category} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      // Usage counters: owner may read; only the server (Admin SDK) writes.
      match /usage/{doc} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // Encrypted Gemini keys: never accessible from the client. The server
    // (Admin SDK) bypasses these rules.
    match /userSecrets/{uid} {
      allow read, write: if false;
    }

    // Feedback submissions: written only by the server (/api/feedback via the
    // Admin SDK); never readable or writable by clients.
    match /feedback/{id} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
