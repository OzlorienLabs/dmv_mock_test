rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public, read-only content. (The question bank currently ships in-app; these
    // rules are ready for when content is also served from Firestore.)
    match /questions/{id}    { allow read: if true; allow write: if false; }
    match /diagrams/{id}     { allow read: if true; allow write: if false; }
    match /mockTests/{id}    { allow read: if true; allow write: if false; }
    match /roadTestGuide/{id} { allow read: if true; allow write: if false; }

    // Per-user data: only the authenticated owner may read or write.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /attempts/{attemptId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /progress/{category} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Public leaderboard: one denormalized doc per opted-in user. Anyone may
    // read the board (it's a public hook to encourage sign-in); only the owner
    // may write (or delete, to opt out) their own entry. Scores are computed
    // client-side, so this is a shared scoreboard, not an anti-cheat record.
    match /leaderboard/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Feedback submissions: written only by the server (/api/feedback via the
    // Admin SDK); never readable or writable by clients.
    match /feedback/{id} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
